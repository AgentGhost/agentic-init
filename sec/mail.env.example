# Mail server config (local development)
# Copy to sec/mail.env and customize

# Domain
DOMAINNAME=factory.local
HOSTNAME=mail.factory.local

# SSL (leave empty for local dev without SSL)
SSL_TYPE=

# Features (disable for development)
ENABLE_SPAMASSASSIN=0
ENABLE_CLAMAV=0
ENABLE_FAIL2BAN=0

# Logging
LOG_LEVEL=info