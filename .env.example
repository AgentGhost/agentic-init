# ==========================================
# .env.example - Multi-Provider AI Setup
# ==========================================
# Kopiere zu .env: cp .env.example .env
# WICHTIG: .env ist via .gitignore geschützt!
# ==========================================

# ==========================================
# 🖥️  LOKALE INFRASTRUKTUR (kein Key nötig!)
# ==========================================
OLLAMA_HOST=http://localhost:11434

# ==========================================
# ☁️  FREE CLOUD PROVIDERS (FREE Tier)
# ==========================================
# Hole mindestens EINEN, idealerweise mehrere für Fallback:

# 1. Google Gemini - BESTE FREE Option (1M tokens/day!)
# Sign up: https://aistudio.google.com/apikey
# Free Tier: 15 RPM, 1M tokens/day, gemini-2.0-flash
GEMINI_API_KEY=

# 2. Groq - SCHNELLSTE Inference (< 1 sec)
# Sign up: https://console.groq.com/keys
# Free Tier: 30 RPM, llama-3.3-70b, llama-3.1-8b
GROQ_API_KEY=

# 3. OpenRouter - VIELE Modelle FREE
# Sign up: https://openrouter.ai/keys
# Free Tier: gemini-flash, llama-3.1-70b:free
OPENROUTER_API_KEY=

# 4. HuggingFace - Inference API
# Sign up: https://huggingface.co/settings/tokens
# Free Tier: Many models available
HF_API_KEY=

# ==========================================
# 💎 PAID CLOUD (Optional)
# ==========================================
# Anthropic Claude - WICHTIG: Hard-Limit setzen!
# Sign up: https://console.anthropic.com
# Settings → Limits → Hard-Limit $16/Monat
ANTHROPIC_API_KEY=
MONTHLY_TOKEN_BUDGET=16.0

# ==========================================
# 📋 REQUIREMENTS MANAGEMENT (Optional)
# ==========================================
# Plane (selbst-gehostet via docker-compose)
# PLANE_API_KEY=
# PLANE_URL=http://localhost:8080

# GitHub (Alternative zu Plane)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxx
# GITHUB_REPO=owner/repo-name
