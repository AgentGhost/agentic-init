# ==========================================
# .env.example - Template für lokale Umgebung
# ==========================================
# Kopiere diese Datei zu .env und fülle die Werte aus:
#   cp .env.example .env
# 
# Wichtig: .env wird von .gitignore ignoriert und sollte niemals
# in Git commitet werden!
# ==========================================

# --- Cloud Intelligenz (Anthropic) ---
# Hole deinen API Key von: https://console.anthropic.com/api/keys
# Setze ZWINGEND ein Hard-Limit von $16/Monat!
ANTHROPIC_API_KEY=sk-ant-api01-xxxxxxxxxxxxxxxxxxxxxxxxx
MONTHLY_TOKEN_BUDGET=16.0

# --- Requirements Management (Plane) ---
# Falls du Plane selbst hostst (docker-compose), trage hier die Keys ein:
PLANE_API_KEY=your_plane_api_token_here
PLANE_URL=http://localhost:8080

# --- Lokale Infrastruktur ---
# Ollama - Lokale AI-Modelle (normalerweise auf Port 11434)
OLLAMA_HOST=http://localhost:11434

# Jenkins (optional, für CI/CD)
JENKINS_URL=http://localhost:8081
JENKINS_USER=admin
JENKINS_TOKEN=your_jenkins_api_token_here

# --- Optional: GitHub Integration ---
# Falls du mit GitHub Actions oder GitHub CLI arbeitest:
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxx
# GITHUB_REPO=owner/repo-name
